      "mkdir -p /etc/xdg/reflector",
      "echo -e '--save /etc/pacman.d/mirrorlist\\n--protocol https\\n--country Switzerland,Germany,France\\n--sort rate\\n--latest 10' > /etc/xdg/reflector/reflector.conf",
